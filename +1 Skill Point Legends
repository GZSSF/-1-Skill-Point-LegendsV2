-- =============== FUNCIONES TOGGLE ===============
local function updateFarmVisuals()
    toggleBtn.Text = farming_enabled and "FLY FARM: ON [K]" or "FLY FARM: OFF [K]"
    toggleBtn.BackgroundColor3 = farming_enabled and NEON_CYAN or Color3.fromRGB(30, 30, 35)
    toggleBtn.TextColor3 = farming_enabled and Color3.new(0,0,0) or Color3.new(1,1,1)
    stablize(farming_enabled)
end

local function updateClickVisuals()
    clickBtn.Text = autoclick_enabled and "AUTOCLICK: ON [L]" or "AUTOCLICK: OFF [L]"
    clickBtn.BackgroundColor3 = autoclick_enabled and NEON_CYAN or Color3.fromRGB(30, 30, 45)
    clickBtn.TextColor3 = autoclick_enabled and Color3.new(0,0,0) or Color3.new(1,1,1)
end

-- =============== INPUT FIX (GLOBAL) ===============
UserInputService.InputBegan:Connect(function(input, processed)
    if processed or not is_script_active then return end
    if input.KeyCode == Enum.KeyCode.K then
        farming_enabled = not farming_enabled
        updateFarmVisuals()
    elseif input.KeyCode == Enum.KeyCode.L then
        autoclick_enabled = not autoclick_enabled
        updateClickVisuals()
    end
end)

-- =============== LÓGICA CORE ===============
local function cleanName(name) return tostring(name):gsub("%s+", "") end

local function getBestTarget(myHrp)
    local npcs = NPC_FOLDER:GetChildren()
    local targetClean = cleanName(selected_npc_name)
    local nearest = nil; local dist = math.huge
    for _, v in ipairs(npcs) do
        if v:IsA("Model") then
            local cName = cleanName(v.Name)
            if (targetClean == "Todos" or cName == targetClean) then
                local rp = v:FindFirstChild("HumanoidRootPart") or v.PrimaryPart
                if rp then
                    local d = (myHrp.Position - rp.Position).Magnitude
                    if d < dist then dist = d; nearest = {model = v, root = rp} end
                end
            end
        end
    end
    return nearest
end

-- BUCLE FARM
task.spawn(function()
    while is_script_active do
        if farming_enabled then
            local currentHrp = getValidHRP()
            if currentHrp then
                stablize(true) -- Asegurar que los BodyMovers existan
                local target = getBestTarget(currentHrp)
                if target and target.root then
                    local offset = target.root.CFrame * CFrame.new(0, farm_distance, 0) * CFrame.Angles(math.rad(-90), 0, 0)
                    local tdist = (currentHrp.Position - offset.Position).Magnitude
                    if tdist > 1 then
                        if currentTween then currentTween:Cancel() end
                        currentTween = TweenService:Create(currentHrp, TweenInfo.new(tdist/FLY_SPEED, Enum.EasingStyle.Linear), {CFrame = offset})
                        currentTween:Play()
                    end
                end
            end
        end
        task.wait(0.1)
    end
end)

-- BUCLE CLICK
task.spawn(function()
    while is_script_active do
        if autoclick_enabled then
            VirtualInputManager:SendMouseButtonEvent(500, 500, 0, true, game, 0)
            task.wait(0.01)
            VirtualInputManager:SendMouseButtonEvent(500, 500, 0, false, game, 0)
        end
        task.wait(0.05)
    end
end)

-- =============== SLIDER & LISTA ===============
local dragging = false
trigger.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
RunService.RenderStepped:Connect(function()
    if dragging then
        local mousePos = UserInputService:GetMouseLocation().X
        local percentage = math.clamp((mousePos - distSlider.AbsolutePosition.X) / distSlider.AbsoluteSize.X, 0, 1)
        fill.Size = UDim2.new(percentage, 0, 1, 0)
        farm_distance = math.floor(5 + (percentage * 195))
        distLabel.Text = "Altura: " .. farm_distance .. " studs"
    end
end)

local function updateList()
    if not is_script_active then return end
    for _, item in ipairs(scroll:GetChildren()) do if item:IsA("TextButton") then item:Destroy() end end
    local counts = {}
    for _, v in ipairs(NPC_FOLDER:GetChildren()) do if v:IsA("Model") then local n = cleanName(v.Name); counts[n] = (counts[n] or 0) + 1 end end
    local sorted = {}
    for n in pairs(counts) do table.insert(sorted, n) end
    table.sort(sorted, function(a, b) return (tonumber(a) or 0) < (tonumber(b) or 0) end)
    local function create(name)
        local b = Instance.new("TextButton", scroll); b.Size = UDim2.new(0.95, 0, 0, 30); b.Text = name .. " ("..(counts[name] or "0")..")"
        b.BackgroundColor3 = (cleanName(selected_npc_name) == name) and NEON_CYAN or Color3.fromRGB(40, 40, 45)
        b.TextColor3 = (cleanName(selected_npc_name) == name) and Color3.new(0,0,0) or Color3.new(1,1,1); b.Font = Enum.Font.Gotham; b.TextSize = 12; Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function() selected_npc_name = name; updateList() end)
    end
    create("Todos"); for _, n in ipairs(sorted) do create(n) end
    scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
end

toggleBtn.MouseButton1Click:Connect(function() farming_enabled = not farming_enabled; updateFarmVisuals() end)
clickBtn.MouseButton1Click:Connect(function() autoclick_enabled = not autoclick_enabled; updateClickVisuals() end)
closeBtn.MouseButton1Click:Connect(function() is_script_active = false; farming_enabled = false; stablize(false); sg:Destroy() end)

updateList(); task.spawn(function() while is_script_active do task.wait(5); updateList() end end)
