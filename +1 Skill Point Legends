local is_script_active = true
local farming_enabled = false
local autoclick_enabled = false
local selected_npc_name = "Todos"
local farm_distance = 10
local currentTween = nil

-- =============== SISTEMA DE CUERPO (REFORZADO) ===============
local function getValidHRP()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        return char.HumanoidRootPart
    end
    return nil
end

local function stablize(state)
    local targetHrp = getValidHRP()
    if not targetHrp then return end
    
    if state then
        local bv = targetHrp:FindFirstChild("GZSSF_BV") or Instance.new("BodyVelocity")
        bv.Name = "GZSSF_BV"; bv.Velocity = Vector3.zero; bv.MaxForce = Vector3.new(9e9, 9e9, 9e9); bv.Parent = targetHrp
        
        local bg = targetHrp:FindFirstChild("GZSSF_BG") or Instance.new("BodyGyro")
        bg.Name = "GZSSF_BG"; bg.CFrame = CFrame.Angles(math.rad(-90), 0, 0); bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9); bg.P = 50000; bg.Parent = targetHrp
    else
        if targetHrp:FindFirstChild("GZSSF_BV") then targetHrp.GZSSF_BV:Destroy() end
        if targetHrp:FindFirstChild("GZSSF_BG") then targetHrp.GZSSF_BG:Destroy() end
    end
end

